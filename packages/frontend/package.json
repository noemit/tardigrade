{
  "name": "@tardigrade/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run build:electron",
    "build:electron": "tsc --project tsconfig.node.json",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.node.json --noEmit",
    "preview": "vite preview",
    "electron:dev": "npm run build:electron && electron ..",
    "start": "electron .."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.12"
  }
}
