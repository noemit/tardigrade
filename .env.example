# LLM configuration (any OpenAI-compatible Chat Completions endpoint)
LLM_API_KEY=your-api-key-here
# Base URL up to (but not including) /chat/completions. Include /v1 — unlike the
# old Cerebras SDK, the OpenAI client does not append it for you.
#   OpenAI    https://api.openai.com/v1
#   Gemini    https://generativelanguage.googleapis.com/v1beta/openai
#   DeepSeek  https://api.deepseek.com/v1
#   Kimi      https://api.moonshot.ai/v1
#   Cerebras  https://api.cerebras.ai/v1
#   Local     http://localhost:11434/v1   (Ollama / LM Studio / vLLM)
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
# Optional preset id (openai | gemini | deepseek | kimi | cerebras | custom).
# Used to skip request fields some providers reject; safe to leave unset.
LLM_PROVIDER=openai

# How many screenshots are sent to the model, to control vision-token cost:
#   high     – full-detail screenshot every step (best accuracy, most tokens)
#   balanced – low-detail screenshot every step (cheaper, one image per action)
#   minimal  – low-detail, only on the first step and after the page changes
LLM_IMAGE_MODE=high

# Tardigrade drives the agent from screenshots, so the model must be multimodal.
# OpenAI gpt-4o and Gemini flash models support vision; DeepSeek and Kimi's
# standard chat models are text-only and will fail on screenshots.

# Legacy Cerebras variables are still read as a fallback if the LLM_* vars
# above are unset, so existing setups keep working:
#   CEREBRAS_API_KEY=...
#   CEREBRAS_BASE_URL=https://api.cerebras.ai
#   CEREBRAS_MODEL=gemma-4-31b

# Backend server configuration
BACKEND_PORT=3001

# Node environment
NODE_ENV=development
